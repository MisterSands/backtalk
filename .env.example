# ============================================================================
# quo-hangup-hook — environment contract
# ============================================================================
# Copy this file to .env and fill in the required values.
# .env is the ONLY source of secrets (it is gitignored — keep it that way).
#
# The worked example below uses OpenRouter, but any OpenAI-compatible
# endpoint (OpenAI, Groq, Ollama, LM Studio) or the native Anthropic API
# works. See the LLM section.
# ============================================================================


# ----------------------------------------------------------------------------
# Quo (formerly OpenPhone)
# ----------------------------------------------------------------------------

# REQUIRED. Your Quo API key, from workspace settings.
# Sent as the raw `Authorization` header value — NO "Bearer " prefix.
QUO_API_KEY=your-quo-api-key-here

# REQUIRED (unless ALLOW_UNSIGNED=1, which is for local dev only).
# The signing secret shown when you create the webhook in the Quo dashboard.
# Comma-separate multiple secrets if you registered more than one webhook
# (e.g. one for call.transcript.completed and one for call.completed).
# Each entry is either the base64 `key` from webhook creation (current
# scheme) or a `whsec_...` value (beta scheme) — both are auto-detected.
QUO_WEBHOOK_SECRET=your-webhook-signing-key-here

# OPTIONAL. A Quo user id (US...) to set as `assignedTo` on every created
# task. Unset = tasks are created unassigned.
#QUO_DEFAULT_ASSIGNEE=USfictional00001


# ----------------------------------------------------------------------------
# LLM — bring your own endpoint
# ----------------------------------------------------------------------------

# "openai" = any OpenAI-compatible chat-completions endpoint
#            (OpenRouter, OpenAI, Groq, Ollama, LM Studio — set LLM_BASE_URL).
# "anthropic" = the native Anthropic Messages API.
# Default: openai
#LLM_PROVIDER=openai

# Base URL for the openai provider. Ignored by the anthropic provider.
# Default: https://openrouter.ai/api/v1
# Fully local example (transcripts never leave your machine):
#   LLM_BASE_URL=http://localhost:11434/v1        (Ollama)
#LLM_BASE_URL=https://openrouter.ai/api/v1

# REQUIRED. API key for the chosen provider.
# (Ollama / LM Studio don't check it — any non-empty string works.)
LLM_API_KEY=your-llm-api-key-here

# REQUIRED. Model id at your provider. The example below is an OpenRouter id.
# Any chat model that can follow a JSON schema works — check your provider's
# model list.
LLM_MODEL=anthropic/claude-haiku-4.5

# OPTIONAL. Retried once if the primary model returns empty/invalid JSON.
# Never taken from input — config only.
#LLM_FALLBACK_MODEL=


# ----------------------------------------------------------------------------
# Extraction behavior
# ----------------------------------------------------------------------------

# 1 = also file the caller's commitments ("I'll call you back Tuesday").
# Default 0 = staff-side promises only (the follow-through gap).
#INCLUDE_CALLER_COMMITMENTS=0

# Calls shorter than this many seconds are skipped before any LLM spend
# (voicemail / misdial guard). Default: 30
#MIN_CALL_SECONDS=30

# Post-validation cap on tasks created per call. Hard ceiling is 8 —
# this var may lower it, never raise it. Default: 8
#MAX_TASKS_PER_CALL=8

# Transcript size cap fed to the model: first 60% + "[... middle trimmed ...]"
# + last 40%. Model-input trimming only — the full transcript is never stored
# anywhere regardless. Default: 24000
#MAX_TRANSCRIPT_CHARS=24000

# Drop extracted commitments below this confidence: low | medium | high.
# Default: medium
#MIN_CONFIDENCE=medium

# Fallback speaker map for forwarded-line edge cases where a staff line
# shows up as an external number. Matching identifiers are forced to AGENT.
# Format: comma-separated "+E164=Display Name" pairs.
#OWNED_NUMBERS=+15555550100=Alex Agent,+15555550101=Bailey Agent

# IANA timezone passed into the prompt metadata so spoken dates
# ("tomorrow", "Tuesday") resolve correctly. Default: UTC
#TIMEZONE=America/New_York


# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------

# Listen port. Default: 8787
#PORT=8787

# 1 = verbose logs INCLUDING transcript text. Default 0: transcripts are
# NEVER logged.
#DEBUG=0

# 1 = no POSTs to Quo at all; intended task payloads are logged with a
# [DRY_RUN] prefix instead. This is the only mode you should run against a
# real account while testing.
#DRY_RUN=0

# Optional JSON file persisting the processed-call-id set across restarts.
# Stores callId + status + timestamp ONLY — no transcript text, no PII.
# Unset = in-memory LRU only.
#IDEMPOTENCY_FILE=.idempotency.json

# In-memory LRU capacity (call ids). Default: 5000
#IDEMPOTENCY_MAX=5000


# ----------------------------------------------------------------------------
# Webhook security
# ----------------------------------------------------------------------------

# Replay window: deliveries signed more than this many seconds away from
# "now" are rejected. Default: 300
#SIGNATURE_SKEW_SECONDS=300

# 1 = skip signature verification. LOCAL DEV ONLY — the server logs a
# warning on every request while this is on. Default: 0
#ALLOW_UNSIGNED=0

# If set, enables POST /replay (manual re-run of a call by id), gated by
# the x-replay-token header (constant-time compare). Unset = endpoint off.
#REPLAY_TOKEN=


# ----------------------------------------------------------------------------
# call.completed fallback (only if you can't subscribe to
# call.transcript.completed)
# ----------------------------------------------------------------------------

# 1 = on call.completed events, retry-poll the transcript endpoint
# (30s/60s/120s/240s/480s). Requires a long-running host — not serverless.
# The webhook-first path needs no polling at all. Default: 0
#FALLBACK_POLL=0
