# dependencies (there should never be any — zero-dependency project)
node_modules/

# secrets — .env is the only secret source and it never gets committed
.env

# local-only files
*.local

# idempotency store (call-id state, written at runtime)
.idempotency.json

# local task ledger (opt-in NDJSON append-log; task metadata, never transcripts)
.backtalk-ledger.ndjson
*.ndjson

# logs
*.log
